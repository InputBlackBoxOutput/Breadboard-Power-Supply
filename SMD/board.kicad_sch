	(text "--------------------------------------------\n# Current limiting resistor\n\nR = (Vs - Vled)/Iled\nVled-red = 2V typical\n\nR @ 5V = 2.2k  Iled = 1.3 mA\nR @ 3.3V = 1.5k Iled = 1.3 mA\nR @ var = 820R Iled =10.9 mA (At Vs-max = 12V)\n--------------------------------------------"
		(exclude_from_sim no)
		(at 95.25 144.78 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "4b36a84f-1f7d-43b9-b138-8462ca1ec882")
	)
